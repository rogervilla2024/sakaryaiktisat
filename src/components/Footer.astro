---
import { SITE, NAV_LINKS, CATEGORIES } from '../lib/constants';
---

<footer class="bg-casino-surface border-t border-casino-border mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-display font-bold text-lg bg-gradient-to-r from-casino-gold to-casino-gold-light bg-clip-text text-transparent">
          SLOT TAKTİKLERİ
        </a>
        <p class="mt-3 text-casino-text-muted text-sm leading-relaxed">
          Slot taktikleri ve casino stratejileri hakkında profesyonel rehberler.
          Matematiksel analiz ile bilinçli oynayın.
        </p>
      </div>

      <!-- Sayfalar -->
      <div>
        <h3 class="font-display font-semibold text-casino-text mb-4">Sayfalar</h3>
        <ul class="space-y-2">
          {NAV_LINKS.map(link => (
            <li>
              <a href={link.href} class="text-casino-text-muted hover:text-casino-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kategoriler -->
      <div>
        <h3 class="font-display font-semibold text-casino-text mb-4">Kategoriler</h3>
        <ul class="space-y-2">
          {Object.entries(CATEGORIES).map(([slug, cat]) => (
            <li>
              <a href={`/kategori/${slug}`} class="text-casino-text-muted hover:text-casino-gold text-sm transition-colors">
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Yasal -->
      <div>
        <h3 class="font-display font-semibold text-casino-text mb-4">Yasal</h3>
        <div class="bg-casino-red/10 border border-casino-red/30 rounded-lg p-4">
          <p class="text-casino-red font-bold text-sm mb-2">18+ Uyarı</p>
          <p class="text-casino-text-muted text-xs leading-relaxed">
            Kumar bağımlılık yapabilir. Bu site yalnızca bilgilendirme amaçlıdır.
            Sorumlu kumar oynayın ve yerel yasaları kontrol edin.
          </p>
        </div>
      </div>
    </div>

    <!-- Linkler -->
    <div class="mt-8 pt-6 border-t border-casino-border text-center text-sm text-casino-text-muted space-x-3">
      <a href="https://anatoljhr.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">slot oyunları</a>
      <a href="https://anatoljhr.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">slot oyna</a>
      <a href="https://anatoljhr.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">demo slot oyna</a>
      <a href="https://demoslotoyna.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">slot oyunları</a>
      <a href="https://demoslotoyna.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">slot oyna</a>
      <a href="https://demoslotoyna.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">demo slot oyna</a>
      <a href="https://www.biosimilars-congress.com/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">casino</a>
      <a href="https://www.turkcasino.net/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">casino</a>
      <a href="https://sweetbonanza.org/" target="_blank" rel="nofollow sponsored noopener" class="hover:text-casino-gold transition-colors">https://sweetbonanza.org/</a>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-casino-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-casino-text-dim text-xs">
        &copy; {new Date().getFullYear()} {SITE.title}. Tüm hakları saklıdır.
      </p>
      <p class="text-casino-text-dim text-xs">
        Bu sitedeki içerikler yatırım tavsiyesi değildir.
      </p>
    </div>
  </div>
</footer>
