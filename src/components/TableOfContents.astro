---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <details class="mb-8 bg-casino-surface border border-casino-border rounded-lg group" open>
    <summary class="px-5 py-3 cursor-pointer font-display font-semibold text-casino-text hover:text-casino-gold transition-colors list-none flex items-center justify-between">
      <span>İçindekiler</span>
      <svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <nav class="px-5 pb-4" aria-label="İçindekiler">
      <ol class="space-y-1">
        {filteredHeadings.map(heading => (
          <li class={heading.depth === 3 ? 'ml-4' : ''}>
            <a
              href={`#${heading.slug}`}
              class="text-sm text-casino-text-muted hover:text-casino-gold transition-colors block py-1"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  </details>
)}
