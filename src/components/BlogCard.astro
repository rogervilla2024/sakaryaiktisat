---
import { CATEGORIES } from '../lib/constants';
import { formatDate } from '../lib/utils';
import type { CategoryKey } from '../lib/constants';

interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  category: CategoryKey;
  readingTime: number;
}

const { title, description, slug, pubDate, category, readingTime } = Astro.props;
const categoryInfo = CATEGORIES[category];
---

<article class="group relative bg-casino-surface border border-casino-border rounded-xl overflow-hidden hover:border-casino-gold/50 hover:-translate-y-1 transition-all duration-300">
  <!-- Image Placeholder -->
  <div class="h-48 bg-gradient-to-br from-casino-surface-light to-casino-bg flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-casino-surface to-transparent" />
    <span class="text-6xl opacity-20 group-hover:opacity-30 transition-opacity group-hover:scale-110 transform duration-300">🎰</span>
    <span class={`absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-semibold text-casino-bg ${categoryInfo.color}`}>
      {categoryInfo.label}
    </span>
  </div>

  <!-- Content -->
  <div class="p-5">
    <h3 class="font-display font-bold text-lg text-casino-text group-hover:text-casino-gold transition-colors mb-2 line-clamp-2">
      <a href={`/blog/${slug}`} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>
    <p class="text-casino-text-muted text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>
    <div class="flex items-center justify-between text-xs text-casino-text-dim">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
      <span>{readingTime} dk okuma</span>
    </div>
  </div>
</article>
