---
---

<section class="relative overflow-hidden py-20 sm:py-28">
  <!-- Background Effects -->
  <div class="absolute inset-0 bg-gradient-to-b from-casino-bg via-casino-surface to-casino-bg" />
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-10 left-10 w-72 h-72 bg-casino-gold/20 rounded-full blur-[128px]" />
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-casino-purple/20 rounded-full blur-[128px]" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-casino-neon/10 rounded-full blur-[128px]" />
  </div>

  <!-- Floating Symbols -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <span class="absolute top-[15%] left-[10%] text-4xl opacity-10 animate-float" style="animation-delay: 0s;">&#9824;</span>
    <span class="absolute top-[25%] right-[15%] text-5xl opacity-10 animate-float" style="animation-delay: 1s;">&#9830;</span>
    <span class="absolute bottom-[20%] left-[20%] text-3xl opacity-10 animate-float" style="animation-delay: 2s;">&#9829;</span>
    <span class="absolute bottom-[30%] right-[10%] text-4xl opacity-10 animate-float" style="animation-delay: 3s;">&#9827;</span>
    <span class="absolute top-[40%] left-[50%] text-6xl opacity-5 animate-float" style="animation-delay: 1.5s;">7</span>
  </div>

  <!-- Content -->
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold leading-tight mb-6">
      <span class="text-casino-text">Slot Taktikleri &</span>
      <br />
      <span class="bg-gradient-to-r from-casino-gold via-casino-gold-light to-casino-gold bg-clip-text text-transparent">
        Casino Stratejileri
      </span>
    </h1>
    <p class="text-lg sm:text-xl text-casino-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Matematiksel analiz ve profesyonel rehberlerle bilinçli oynayın.
      RTP, volatilite ve oyun mekaniklerini derinlemesine öğrenin.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/blog"
        class="inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-r from-casino-gold to-casino-gold-light text-casino-bg font-display font-bold rounded-lg hover:shadow-[0_0_30px_rgba(245,166,35,0.3)] transition-all hover:-translate-y-0.5 animate-pulse-gold"
      >
        Rehberleri Keşfet
      </a>
      <a
        href="/kategori/strateji"
        class="inline-flex items-center justify-center px-8 py-3.5 border border-casino-border text-casino-text font-display font-semibold rounded-lg hover:border-casino-neon hover:text-casino-neon transition-all animate-pulse-neon"
      >
        Stratejilere Göz At
      </a>
    </div>

    <!-- Stats -->
    <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
      <div class="glass rounded-xl p-4 text-center">
        <p class="text-2xl font-display font-bold text-casino-gold">20+</p>
        <p class="text-xs text-casino-text-muted mt-1">Detaylı Rehber</p>
      </div>
      <div class="glass rounded-xl p-4 text-center">
        <p class="text-2xl font-display font-bold text-casino-neon">4</p>
        <p class="text-xs text-casino-text-muted mt-1">Kategori</p>
      </div>
      <div class="glass rounded-xl p-4 text-center">
        <p class="text-2xl font-display font-bold text-casino-purple">5</p>
        <p class="text-xs text-casino-text-muted mt-1">Oyun İnceleme</p>
      </div>
      <div class="glass rounded-xl p-4 text-center">
        <p class="text-2xl font-display font-bold text-casino-red">18+</p>
        <p class="text-xs text-casino-text-muted mt-1">Sorumlu Kumar</p>
      </div>
    </div>
  </div>
</section>
